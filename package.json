{
  "name": "gino-home",
  "version": "1.0.0",
  "description": "Gino-Home – Haushaltsverwaltung für Zuhause",
  "private": true,
  "main": "electron/main.js",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=backend\" \"npm run dev --workspace=frontend\"",
    "electron:dev": "electron .",
    "build:frontend": "npm run build --workspace=frontend",
    "build:win":   "electron-builder --win --x64",
    "build:mac":   "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all":   "electron-builder --win --mac --linux",
    "install:all": "npm install && npm install --workspace=backend && npm install --workspace=frontend"
  },
  "build": {
    "appId": "de.gino-home.app",
    "productName": "Gino-Home",
    "copyright": "Copyright © 2024",
    "asar": true,
    "files": [
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist-app",
      "buildResources": "electron"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "electron/icon.ico",
      "artifactName": "Gino-Home-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "Gino-Home-Portable-${version}.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": [
        "de_DE"
      ],
      "language": "1031",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Gino-Home"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "electron/icon.icns",
      "category": "public.app-category.productivity",
      "artifactName": "Gino-Home-${version}.${ext}"
    },
    "dmg": {
      "title": "Gino-Home ${version}",
      "background": null,
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "electron/icon.png",
      "category": "Office"
    }
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^41.3.0",
    "electron-builder": "^24.13.3"
  }
}
