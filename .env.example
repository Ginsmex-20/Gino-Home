# ── Gino-Home Produktions-Konfiguration ──────────────────
# Diese Datei als ".env" kopieren und Werte anpassen
# cp .env.example .env

# PFLICHT: Sicherer zufälliger String (mind. 32 Zeichen)
# Generieren: openssl rand -hex 32
JWT_SECRET=ersetze-mich-mit-einem-langen-zufaelligen-string

# Optional: Wenn du über eine andere IP/Domain erreichst
# CORS_ORIGIN=http://192.168.1.50:8080,http://meinedomain.de

# ── E-Mail via Gmail SMTP (optional) ─────────────────────
# Schritt 1: Google-Konto → Sicherheit → 2-Schritt-Verifizierung aktivieren
# Schritt 2: Google-Konto → Sicherheit → App-Passwörter → "Gino-Home" erstellen
# Schritt 3: Das 16-stellige App-Passwort unten eintragen (keine Leerzeichen)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=deine@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM=Gino-Home <deine@gmail.com>
